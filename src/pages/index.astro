---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Personal blog by Nishanth M — backend, frontend, tools, and startup experiences."
>
  <section class="hero hero-gradient" style="padding: var(--space-section) 1.5rem; max-width: var(--wide-width); margin: 0 auto;">
    <h1 class="gradient-text" style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1rem;">
      Hey, I'm Nishanth 👋
    </h1>
    <p style="color: var(--color-text-secondary); font-size: 1.15rem; max-width: 600px; line-height: 1.7;">
      I build real systems and document the journey. Exploring backend, frontend,
      mobile, and everything in between.
    </p>
  </section>
</BaseLayout>
