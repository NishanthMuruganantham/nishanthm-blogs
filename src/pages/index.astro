---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import PostCard from "../components/PostCard.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../lib/utils";

// Fetch all non-draft posts
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Sort newest first
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Get the specific featured post
const featuredPost = sortedPosts.find((p) => p.data.featured);

// Get reading time for featured post if it exists
const featuredPostWithMeta = featuredPost ? {
  ...featuredPost,
  readingTime: featuredPost.body ? getReadingTime(featuredPost.body) : undefined,
} : null;

// Get latest posts (excluding the featured one)
const latestPosts = sortedPosts
  .filter((p) => p.slug !== featuredPost?.slug)
  .slice(0, 3);

const latestPostsWithMeta = latestPosts.map((post) => ({
  ...post,
  readingTime: post.body ? getReadingTime(post.body) : undefined,
}));

// Count posts per category
const categories = [
  { name: "Backend", emoji: "⚙️", color: "backend" },
  { name: "Frontend", emoji: "🎨", color: "frontend" },
  { name: "Tools", emoji: "🛠️", color: "tools" },
  { name: "Android", emoji: "📱", color: "android" },
  { name: "Startup", emoji: "🚀", color: "startup" },
];

const categoryCounts = categories.map((cat) => ({
  ...cat,
  count: allPosts.filter((p) => p.data.category === cat.name).length,
}));

// ── Parallax Stars: generate random box-shadow positions at build time ──
function generateBoxShadows(n: number, color: string): string {
  const shadows: string[] = [];
  for (let i = 0; i < n; i++) {
    const x = Math.floor(Math.random() * 2000);
    const y = Math.floor(Math.random() * 2000);
    shadows.push(`${x}px ${y}px ${color}`);
  }
  return shadows.join(', ');
}

// Dark mode: white stars
const starsSmall  = generateBoxShadows(700, '#FFF');
const starsMedium = generateBoxShadows(200, '#FFF');
const starsBig    = generateBoxShadows(100, '#FFF');

// Light mode: dark indigo dots at different intensities
const starsSmallL  = generateBoxShadows(700, '#6366f1');
const starsMediumL = generateBoxShadows(200, '#4338ca');
const starsBigL    = generateBoxShadows(100, '#312e81');
---

<BaseLayout
  title="Home"
  description="Personal blog by Nishanth M, documenting engineering challenges in Django, AWS, and Agentic AI."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero hero-gradient hero--space" id="hero-section">
    <div class="hero__glow-blob" aria-hidden="true"></div>

    <!-- Parallax star layers — DARK MODE (white stars) -->
    <div class="hero__stars hero__stars--small hero__stars--dark" aria-hidden="true"
         style={`box-shadow: ${starsSmall};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsSmall};`}></div>
    </div>
    <div class="hero__stars hero__stars--medium hero__stars--dark" aria-hidden="true"
         style={`box-shadow: ${starsMedium};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsMedium};`}></div>
    </div>
    <div class="hero__stars hero__stars--big hero__stars--dark" aria-hidden="true"
         style={`box-shadow: ${starsBig};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsBig};`}></div>
    </div>

    <!-- Parallax star layers — LIGHT MODE (dark indigo dots) -->
    <div class="hero__stars hero__stars--small hero__stars--light" aria-hidden="true"
         style={`box-shadow: ${starsSmallL};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsSmallL};`}></div>
    </div>
    <div class="hero__stars hero__stars--medium hero__stars--light" aria-hidden="true"
         style={`box-shadow: ${starsMediumL};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsMediumL};`}></div>
    </div>
    <div class="hero__stars hero__stars--big hero__stars--light" aria-hidden="true"
         style={`box-shadow: ${starsBigL};`}>
      <div class="hero__stars-after" style={`box-shadow: ${starsBigL};`}></div>
    </div>

    <div class="hero__content" id="hero-content">
      <p class="hero__eyebrow anim-fade" style="--delay: 0">
        Developer · Builder · Writer
      </p>

      <h1 class="hero__heading gradient-text anim-fade" style="--delay: 1">
        I Build Systems and<br />Document the Journey
      </h1>

      <p class="hero__sub anim-fade" style="--delay: 2">
        I’m Nishanth, an indie developer and software engineer building production systems with Django, AWS, and Agentic AI. I specialize in architecting robust backends and developing autonomous workflows using N8N and the Model Context Protocol (MCP).
      </p>

      <div class="hero__cta anim-fade" style="--delay: 3">
        <Button as="a" href="/blog" variant="primary" id="cta-blog">Read the Blog</Button>
        <Button as="a" href="https://portfolio.nishanthm.com" target="_blank" rel="noopener noreferrer" variant="ghost" id="cta-about">About Me</Button>
      </div>
    </div>
  </section>

  <!-- =============== FEATURED POSTS =============== -->
  <section class="section" id="latest-writing">
    <div class="section__inner">
      {featuredPostWithMeta && <FeaturedPost post={featuredPostWithMeta} readingTime={featuredPostWithMeta.readingTime} />}
      
      <h2 class="section__title">Latest Writing</h2>
      <div class="posts-grid">
        {
          latestPostsWithMeta.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              tags={post.data.tags}
              slug={post.slug}
              readingTime={post.readingTime}
              cover={post.data.cover}
            />
          ))
        }
      </div>
      <div class="section__cta">
        <a href="/blog" class="btn-ghost" id="cta-all-posts">View all posts →</a
        >
      </div>
    </div>
  </section>

  <!-- =============== CATEGORIES =============== -->
  <section class="section" id="categories-section">
    <div class="section__inner">
      <h2 class="section__title">Browse by Topic</h2>
      <div class="categories-grid">
        {
          categoryCounts.map((cat) => (
            <a
              href="/categories/"
              class={`category-card category-card--${cat.color}`}
              id={`cat-${cat.color}`}
            >
              <span class="category-card__emoji">{cat.emoji}</span>
              <span class="category-card__name">{cat.name}</span>
              <span class="category-card__count">
                {cat.count} {cat.count === 1 ? "post" : "posts"}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =============== ABOUT TEASER =============== -->
  <section class="section" id="about-teaser">
    <div class="section__inner about-grid">
      <div class="about-text">
        <h2 class="section__title">Who am I?</h2>
        <p class="about-bio">
          I’m a full-stack engineer focused on building end-to-end systems that scale. My current expertise lies in architecting Django-powered backends on AWS and implementing Agentic AI workflows with N8N and MCP. I document the hard-won lessons from production environments to help fellow builders ship faster.
        </p>
        <ul class="about-stack">
          <li><strong>Backend:</strong> Django, Python, AWS</li>
          <li><strong>Agentic AI:</strong> MCP, N8N, LLM Orchestration</li>
          <li><strong>Frontend:</strong> React, Astro, Tailwind CSS</li>
          <li><strong>Mobile:</strong> Android (Kotlin), Gradle</li>
        </ul>
        <a href="https://portfolio.nishanthm.com" target="_blank" rel="noopener noreferrer" class="about-link" id="about-link">
          Read more about me →
        </a>
      </div>
      <div class="about-visual" aria-hidden="true">
        <div class="code-snippet-card">
          <div class="code-snippet__header">
            <span class="code-snippet__dot code-snippet__dot--red"></span>
            <span class="code-snippet__dot code-snippet__dot--yellow"></span>
            <span class="code-snippet__dot code-snippet__dot--green"></span>
            <span class="code-snippet__filename">about.py</span>
          </div>
          <pre
            class="code-snippet__body"><code><span class="code-kw">class</span> <span class="code-cls">Developer</span>:
    name = <span class="code-str">"Nishanth M"</span>
    role = <span class="code-str">"AI &amp; Backend Engineer"</span>
    stack = [<span class="code-str">"Django"</span>, <span class="code-str">"AWS"</span>, <span class="code-str">"Agentic AI"</span>]

    <span class="code-kw">def</span> <span class="code-fn">passion</span>(self):
        <span class="code-kw">return</span> <span class="code-str">"Building &amp; Writing"</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== NEWSLETTER ============== -->
  <section class="section section--newsletter" id="newsletter-section">
    <div class="section__inner newsletter-inner">
      <h2 class="newsletter__title">Stay Updated</h2>
      <p class="newsletter__sub">
        Get notified when I publish new articles. No spam — just clean, useful
        dev content.
      </p>
      <div class="newsletter__form" style="justify-content: center;">
        <a href="https://buttondown.com" target="_blank" class="btn-primary">
          Subscribe via Buttondown
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* =====================================================
     HERO SECTION
     ===================================================== */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 90vh;
    padding: 6rem 1.5rem 6rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Smooth bottom fade — blends hero into page content seamlessly */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 160px;
    background: linear-gradient(to bottom, transparent 0%, var(--color-bg) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Deep-space radial gradient — DARK mode default */
  .hero--space {
    background: radial-gradient(ellipse at bottom, #1B2735 0%, #090A0F 100%);
  }

  /* Light mode override: soft sky-dawn gradient */
  :global(html:not(.dark)) .hero--space {
    background: radial-gradient(ellipse at 50% 110%, #c7d7f8 0%, #dde8ff 40%, #f0f4ff 100%);
  }

  /* Light mode: tint the glow blob to a softer indigo */
  :global(html:not(.dark)) .hero__glow-blob {
    background: radial-gradient(circle, rgba(124, 106, 247, 0.15) 0%, transparent 70%);
    opacity: 0.6;
  }

  /* ── Star theme visibility ── */
  .hero__stars--dark  { display: block; }
  .hero__stars--light { display: none;  }

  :global(html:not(.dark)) .hero__stars--dark  { display: none;  }
  :global(html:not(.dark)) .hero__stars--light { display: block; }

  /* ── Light mode font contrast overrides ── */

  /* Eyebrow: deep indigo so it pops on lavender */
  :global(html:not(.dark)) .hero__eyebrow {
    color: #3730a3;
  }

  /* Heading gradient: dark indigo → violet → deep blue — high contrast on light bg */
  :global(html:not(.dark)) .hero__heading {
    background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 45%, #1d4ed8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtext: near-black for maximum legibility */
  :global(html:not(.dark)) .hero__sub {
    color: #1e293b;
  }

  /* ── Parallax Star Layers ── */
  .hero__stars {
    position: absolute;
    top: 0;
    left: 0;
    background: transparent;
    z-index: 0;
    pointer-events: none;
  }

  .hero__stars-after {
    position: absolute;
    top: 2000px;
    background: transparent;
  }

  /* Layer 1: Small (1px, slowest) — dim, distant */
  .hero__stars--small,
  .hero__stars--small .hero__stars-after {
    width: 1px;
    height: 1px;
  }
  .hero__stars--small {
    animation: animStar 50s linear infinite;
    opacity: 0.35;
  }
  :global(html:not(.dark)) .hero__stars--small { opacity: 0.55; }

  /* Layer 2: Medium (2px) — mid-bright */
  .hero__stars--medium,
  .hero__stars--medium .hero__stars-after {
    width: 2px;
    height: 2px;
  }
  .hero__stars--medium {
    animation: animStar 100s linear infinite;
    opacity: 0.65;
  }
  :global(html:not(.dark)) .hero__stars--medium { opacity: 0.8; }

  /* Layer 3: Big (3px) — bright, closest */
  .hero__stars--big,
  .hero__stars--big .hero__stars-after {
    width: 3px;
    height: 3px;
  }
  .hero__stars--big {
    animation: animStar 150s linear infinite;
    opacity: 1;
  }

  @keyframes animStar {
    from { transform: translateY(0); }
    to   { transform: translateY(-2000px); }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__stars { animation: none !important; }
  }

  .hero__content {
    max-width: 720px;
    position: relative;
    z-index: 2;
  }

  .hero__eyebrow {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent-bright);
    margin-bottom: 1.25rem;
  }

  .hero__heading {
    font-size: clamp(2.2rem, 5.5vw, 3.75rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero__sub {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Glowing animated blob */
  .hero__glow-blob {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-accent-40) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    filter: blur(60px);
    border-radius: 50%;
    z-index: 0;
    opacity: 0.8;
    pointer-events: none;
    animation: blobPulse 8s ease-in-out infinite alternate;
  }

  @keyframes blobPulse {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.6;
    }
    100% {
      transform: translate(-50%, -50%) scale(1.15);
      opacity: 0.9;
    }
  }

  /* Staggered fade-in animation */
  .anim-fade {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(24px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay) * 0.15s);
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  /* =====================================================
     SHARED SECTION LAYOUT
     ===================================================== */
  .section {
    padding: var(--space-section) 1.5rem;
  }

  .section__inner {
    max-width: var(--wide-width);
    margin: 0 auto;
  }

  .section__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-text-primary);
    margin-bottom: 2.5rem;
  }

  .section__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* =====================================================
     POSTS GRID
     ===================================================== */
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* =====================================================
     CATEGORIES GRID
     ===================================================== */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border-subtle);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .category-card:hover {
    transform: translateY(-3px);
    border-color: transparent;
  }

  /* Category-specific backgrounds (10% opacity) */
  .category-card--backend {
    background: rgba(249, 115, 22, 0.06);
  }
  .category-card--frontend {
    background: rgba(59, 130, 246, 0.06);
  }
  .category-card--tools {
    background: rgba(168, 85, 247, 0.06);
  }
  .category-card--android {
    background: rgba(34, 197, 94, 0.06);
  }
  .category-card--startup {
    background: rgba(236, 72, 153, 0.06);
  }

  /* Hover fills */
  .category-card--backend:hover {
    background: rgba(249, 115, 22, 0.18);
    box-shadow: 0 8px 24px rgba(249, 115, 22, 0.12);
  }
  .category-card--frontend:hover {
    background: rgba(59, 130, 246, 0.18);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.12);
  }
  .category-card--tools:hover {
    background: rgba(168, 85, 247, 0.18);
    box-shadow: 0 8px 24px rgba(168, 85, 247, 0.12);
  }
  .category-card--android:hover {
    background: rgba(34, 197, 94, 0.18);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.12);
  }
  .category-card--startup:hover {
    background: rgba(236, 72, 153, 0.18);
    box-shadow: 0 8px 24px rgba(236, 72, 153, 0.12);
  }

  .category-card__emoji {
    font-size: 1.75rem;
    line-height: 1;
  }

  .category-card__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text-primary);
  }

  .category-card--backend .category-card__name {
    color: var(--color-backend);
  }
  .category-card--frontend .category-card__name {
    color: var(--color-frontend);
  }
  .category-card--tools .category-card__name {
    color: var(--color-tools);
  }
  .category-card--android .category-card__name {
    color: var(--color-android);
  }
  .category-card--startup .category-card__name {
    color: var(--color-startup);
  }

  .category-card__count {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* =====================================================
     ABOUT TEASER
     ===================================================== */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-bio {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .about-stack {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-stack li {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .about-stack li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .about-stack li strong {
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-weight: 700;
  }

  .about-link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-accent-bright);
    transition: color var(--transition-fast);
  }

  .about-link:hover {
    color: var(--color-accent);
  }

  /* Code snippet card */
  .code-snippet-card {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 0.75rem;
    overflow: hidden;
    font-size: 0.85rem;
    box-shadow: 0 8px 32px var(--glass-shadow);
  }

  .code-snippet__header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--code-lang-bg);
    border-bottom: 1px solid var(--code-border);
  }

  .code-snippet__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-snippet__dot--red {
    background: #ff5f57;
  }
  .code-snippet__dot--yellow {
    background: #febc2e;
  }
  .code-snippet__dot--green {
    background: #28c840;
  }

  .code-snippet__filename {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .code-snippet__body {
    padding: 1.25rem 1rem;
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    line-height: 1.7;
    color: var(--color-text-primary);
    background: transparent;
    border: none;
  }

  .code-snippet__body code {
    font-family: inherit;
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .code-kw {
    color: var(--color-accent-bright);
  }
  .code-cls {
    color: #fbbf24;
  }
  .code-str {
    color: #4ade80;
  }
  .code-fn {
    color: #60a5fa;
  }

  /* =====================================================
     NEWSLETTER
     ===================================================== */
  .section--newsletter {
    border-top: 1px solid var(--color-border-subtle);
    text-align: center;
  }

  .newsletter-inner {
    max-width: 520px;
  }

  .newsletter__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .newsletter__sub {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .newsletter__form {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color var(--transition-fast);
    outline: none;
  }

  .newsletter__input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter__input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }

  .newsletter__btn {
    white-space: nowrap;
  }

  .newsletter__note {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  @media (max-width: 480px) {
    .newsletter__form {
      flex-direction: column;
    }
  }
</style>

<script>
  // Subtle parallax effect for the hero section
  const heroContent = document.getElementById('hero-content');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (heroContent && !prefersReducedMotion.matches) {
    window.addEventListener('scroll', () => {
      // Only animate if hero is in view
      if (window.scrollY < window.innerHeight) {
        requestAnimationFrame(() => {
          const yPos = window.scrollY * 0.3; // Parallax speed multiplier
          const opacity = 1 - (window.scrollY / window.innerHeight) * 1.5;
          heroContent.style.transform = `translateY(${yPos}px)`;
          heroContent.style.opacity = String(opacity > 0 ? opacity : 0);
        });
      }
    });
  }
</script>
