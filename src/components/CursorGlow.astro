---
/**
 * CursorGlow — a fixed, page-wide cursor-following emerald spotlight.
 * Sits at z-index -1, so it never covers cards, sidebars, or any content.
 * Automatically hidden in light mode (only looks good on dark backgrounds).
 */
---

<div id="cursor-glow" aria-hidden="true"></div>

<style>
  #cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 99;
    background: radial-gradient(
      circle,
      rgba(68, 239, 159, 0.22) 0%,
      rgba(68, 239, 159, 0.08) 40%,
      transparent 70%
    );
    filter: blur(50px);
    transform: translate(-50%, -50%);
    /* Start off-screen until first mousemove */
    opacity: 0;
    transition: opacity 0.6s ease;
    will-change: transform;
  }

  /* Light mode: significantly more vivid green to cut through white background */
  :global(html:not(.dark)) #cursor-glow {
    background: radial-gradient(
      circle,
      rgba(52, 211, 153, 0.55) 0%,
      rgba(52, 211, 153, 0.2) 35%,
      transparent 65%
    );
    filter: blur(40px); /* Slightly sharper in light mode */
  }
</style>

<script>
  const glow = document.getElementById('cursor-glow') as HTMLElement | null;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (glow && !prefersReducedMotion.matches) {
    let targetX = window.innerWidth / 2;
    let targetY = window.innerHeight / 2;
    let currentX = targetX;
    let currentY = targetY;
    let visible = false;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      targetX = e.clientX;
      targetY = e.clientY;

      if (!visible) {
        glow.style.opacity = '1';
        visible = true;
      }
    });

    function animate() {
      if (!glow) return;
      // Lerp: smooth lag factor — 0.08 = dreamy, organic follow
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      // Use transform instead of top/left for GPU-accelerated movement
      glow.style.transform = `translate(${currentX - 300}px, ${currentY - 300}px)`;

      requestAnimationFrame(animate);
    }
    animate();
  }
</script>
