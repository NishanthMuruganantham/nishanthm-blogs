---
/**
 * CursorGlow — a cursor-following emerald spotlight.
 * Can be 'fixed' (viewport-wide) or 'absolute' (constrained to a relative container).
 * Sits at z-index -1 by default in fixed mode, or configurable.
 */
interface Props {
  absolute?: boolean;
}

const { absolute = false } = Astro.props;
---

<div id="cursor-glow" class={absolute ? 'absolute-glow' : 'fixed-glow'} aria-hidden="true"></div>

<style>
  #cursor-glow {
    width: 600px;
    height: 600px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1; /* Sits above background network but below content */
    background: radial-gradient(
      circle,
      rgba(68, 239, 159, 0.22) 0%,
      rgba(68, 239, 159, 0.08) 40%,
      transparent 70%
    );
    filter: blur(50px);
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.6s ease;
    will-change: transform;
  }

  .fixed-glow {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 99;
  }

  .absolute-glow {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Light mode: significantly more vivid green to cut through white background */
  :global(html:not(.dark)) #cursor-glow {
    background: radial-gradient(
      circle,
      rgba(52, 211, 153, 0.55) 0%,
      rgba(52, 211, 153, 0.2) 35%,
      transparent 65%
    );
    filter: blur(40px);
  }
</style>

<script>
  function initGlow() {
    const glow = document.getElementById('cursor-glow') as HTMLElement | null;
    if (!glow) return;

    const isAbsolute = glow.classList.contains('absolute-glow');
    const container = isAbsolute ? glow.parentElement : null;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (!prefersReducedMotion.matches) {
      let targetX = 0;
      let targetY = 0;
      let currentX = 0;
      let currentY = 0;
      let visible = false;

      const updateTarget = (e: MouseEvent) => {
        if (isAbsolute && container) {
          const rect = container.getBoundingClientRect();
          // Coordinates relative to the container
          targetX = e.clientX - rect.left;
          targetY = e.clientY - rect.top;
        } else {
          targetX = e.clientX;
          targetY = e.clientY;
        }

        if (!visible) {
          glow.style.opacity = '1';
          visible = true;
          // Sync current to target immediately on first move to avoid jump from (0,0)
          currentX = targetX;
          currentY = targetY;
        }
      };

      document.addEventListener('mousemove', updateTarget);

      function animate() {
        if (!glow) return;
        // Lerp: smooth lag factor
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;

        glow.style.transform = `translate(${currentX - 300}px, ${currentY - 300}px)`;

        requestAnimationFrame(animate);
      }
      animate();
    }
  }

  // Initialize on load and on page transitions
  document.addEventListener('astro:page-load', initGlow);
  initGlow();
</script>
