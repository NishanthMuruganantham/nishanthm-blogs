---
import { formatDate } from "../lib/utils";

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  slug: string;
  readingTime?: string;
  cover?: string;
}

const { title, description, date, category, tags, slug, readingTime, cover } =
  Astro.props;
const categoryLower = category.toLowerCase();
---

<a href={`/blog/${slug}/`} class="post-card card" id={`post-${slug}`}>
  {
    cover && (
      <div class="post-card__cover">
        <img src={cover} alt={title} loading="lazy" decoding="async" />
      </div>
    )
  }
  <div class="post-card__content">
    <div class="post-card__header">
      <span class={`tag tag-${categoryLower}`}>{category}</span>
    </div>

    <h3 class="post-card__title">{title}</h3>
    <p class="post-card__description">{description}</p>

    <div class="post-card__meta">
      <time datetime={date.toISOString()}>
        {formatDate(date)}
      </time>
      {readingTime && <span class="post-card__dot">·</span>}
      {readingTime && <span>{readingTime}</span>}
    </div>

    {
      tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="post-card__tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    /* padding is on the card class in global.css, so we adjust content specifically to bleed image */
  }

  .post-card__cover {
    border-radius: 0.5rem 0.5rem 0 0;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    margin: -1.5rem -1.5rem 1rem; /* bleed to card edges, negative margin based on .card padding */
  }

  .post-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .post-card:hover .post-card__cover img {
    transform: scale(1.03);
  }

  .post-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .post-card:hover .post-card__title {
    color: var(--color-accent-bright);
  }

  .post-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
    margin: 0;
  }

  .post-card__description {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-card__dot {
    opacity: 0.5;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  .post-card__tag {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 9999px;
    background: var(--color-accent-glow);
    color: var(--color-text-secondary);
    transition: background var(--transition-fast);
  }

  .post-card:hover .post-card__tag {
    background: rgba(124, 106, 247, 0.25);
  }
</style>
