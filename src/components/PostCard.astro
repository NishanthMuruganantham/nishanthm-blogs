---
import { formatDate } from "../lib/utils";

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  slug: string;
  readingTime?: string;
  cover?: string;
}

const { title, description, date, category, tags, slug, readingTime, cover } =
  Astro.props;
const categoryLower = category.toLowerCase();
---

<a href={`/blog/${slug}/`} class="post-card card" id={`post-${slug}`}>
  {
    cover && (
      <div class="post-card__cover">
        <img src={cover} alt={title} loading="lazy" decoding="async" />
      </div>
    )
  }
  <div class="post-card__content">
    <div class="post-card__header">
      <span class={`tag tag-${categoryLower}`}>{category}</span>
    </div>

    <h3 class="post-card__title">{title}</h3>
    <p class="post-card__description">{description}</p>

    <div class="post-card__meta">
      <time datetime={date.toISOString()}>
        {formatDate(date)}
      </time>
      {readingTime && <span class="post-card__dot">·</span>}
      {readingTime && <span>{readingTime}</span>}
    </div>

    {
      tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="post-card__tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
