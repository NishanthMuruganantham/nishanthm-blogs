---
import { formatDate, slugify } from "../lib/utils";

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  slug: string;
  readingTime?: string;
  cover?: string;
}

const { title, description, date, category, tags, slug, readingTime, cover } =
  Astro.props;
const categoryLower = category.toLowerCase();
---

<div class="post-card card" id={`post-${slug}`}>
  {
    cover && (
      <a href={`/blog/${slug}/`} class="post-card__cover" tabindex="-1" aria-hidden="true">
        <img src={cover} alt={title} loading="lazy" decoding="async" />
      </a>
    )
  }
  <div class="post-card__content">
    <div class="post-card__header">
      <a href={`/categories/${slugify(category)}/`} class={`tag tag-${categoryLower}`}>{category}</a>
    </div>

    <h3 class="post-card__title">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    <p class="post-card__description">{description}</p>

    <div class="post-card__meta">
      <time datetime={date.toISOString()}>
        {formatDate(date)}
      </time>
      {readingTime && <span class="post-card__dot">·</span>}
      {readingTime && <span>{readingTime}</span>}
    </div>

    {
      tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 3).map((tag) => (
            <a href={`/tags/${slugify(tag)}/`} class="post-card__tag">#{tag}</a>
          ))}
        </div>
      )
    }
  </div>
</div>
