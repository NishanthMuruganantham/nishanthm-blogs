---
/**
 * ShareButtons.astro
 * Social share buttons for blog posts.
 * Renders as floating sidebar (desktop) or inline section (mobile).
 *
 * Brand SVG icons sourced from Simple Icons (https://simpleicons.org)
 * Utility icons sourced from Lucide (https://lucide.dev)
 */

interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url, description = "" } = Astro.props;

// Build full absolute URL for sharing
const siteUrl = "https://blogs.nishanthm.com";
const shareUrl = `${siteUrl}${url}`;

// Encode for URL parameters
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(shareUrl);
const encodedDescription = encodeURIComponent(description);

// Share URLs for each platform
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;

// SVG icon paths — sourced from Simple Icons (https://simpleicons.org)
// X (Twitter): https://simpleicons.org/?q=x
const xIconPath =
  "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z";
// LinkedIn: https://simpleicons.org/?q=linkedin
const linkedinIconPath =
  "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z";
---

<!-- ============================================================
     Desktop: Floating Sidebar (left side, icon-only)
     Visible on lg+ screens only
     ============================================================ -->
<div class="share-float" aria-label="Share this article">
  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn"
    aria-label="Share on X (Twitter)"
    title="Share on X"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d={xIconPath}></path>
    </svg>
  </a>

  <a
    href={linkedinUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn"
    aria-label="Share on LinkedIn"
    title="Share on LinkedIn"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d={linkedinIconPath}></path>
    </svg>
  </a>

  <button
    class="share-btn share-copy-btn"
    data-share-url={shareUrl}
    aria-label="Copy link to clipboard"
    title="Copy link"
  >
    <!-- Lucide: Link icon (https://lucide.dev/icons/link) -->
    <svg
      class="share-copy-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
      ></path>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
      ></path>
    </svg>
    <!-- Lucide: Check icon (shown after copy) -->
    <svg
      class="share-check-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="display:none;"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <span class="share-tooltip">Copied!</span>
  </button>
</div>

<!-- ============================================================
     Mobile: Inline Section (full buttons with labels)
     Visible on < lg screens only
     ============================================================ -->
<div class="share-inline" aria-label="Share this article">
  <h3 class="share-inline__heading">Spread the word!</h3>

  <div class="share-inline__buttons">
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-inline-btn"
      aria-label="Share on X (Twitter)"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d={xIconPath}></path>
      </svg>
      <span>Post on X</span>
    </a>

    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-inline-btn"
      aria-label="Share on LinkedIn"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d={linkedinIconPath}></path>
      </svg>
      <span>LinkedIn</span>
    </a>

    <button
      class="share-inline-btn share-copy-btn"
      data-share-url={shareUrl}
      aria-label="Copy link to clipboard"
    >
      <svg
        class="share-copy-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
        ></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
        ></path>
      </svg>
      <svg
        class="share-check-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        style="display:none;"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="share-copy-label">Copy Link</span>
      <span class="share-tooltip">Copied!</span>
    </button>

    <!-- Native Share API button — hidden by default, shown via JS if supported -->
    <button
      class="share-inline-btn share-native-btn"
      data-share-title={title}
      data-share-url={shareUrl}
      data-share-text={description}
      aria-label="Share via device share menu"
      style="display: none;"
    >
      <!-- Lucide: Share icon (https://lucide.dev/icons/share) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
        <polyline points="16 6 12 2 8 6"></polyline>
        <line x1="12" y1="2" x2="12" y2="15"></line>
      </svg>
      <span>More...</span>
    </button>
  </div>
</div>

<!-- ============================================================
     Client-side: Copy to clipboard + Native Share API
     ============================================================ -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Copy Link Buttons ---
    const copyButtons = document.querySelectorAll(".share-copy-btn");

    copyButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const url = btn.getAttribute("data-share-url");
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);

          // Swap icons: hide link, show check
          const linkIcon = btn.querySelector(".share-copy-icon") as HTMLElement;
          const checkIcon = btn.querySelector(
            ".share-check-icon",
          ) as HTMLElement;
          const label = btn.querySelector(".share-copy-label");
          const tooltip = btn.querySelector(".share-tooltip");

          if (linkIcon) linkIcon.style.display = "none";
          if (checkIcon) {
            checkIcon.style.display = "block";
            checkIcon.style.color = "#4ade80";
          }
          if (label) label.textContent = "Copied!";
          if (tooltip) tooltip.classList.add("show");

          // Add success class for green glow
          btn.classList.add("share-btn--copied");

          // Reset after 2s
          setTimeout(() => {
            if (linkIcon) linkIcon.style.display = "block";
            if (checkIcon) checkIcon.style.display = "none";
            if (label) label.textContent = "Copy Link";
            if (tooltip) tooltip.classList.remove("show");
            btn.classList.remove("share-btn--copied");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy link:", err);
        }
      });
    });

    // --- Native Share API (mobile button) ---
    const nativeButtons = document.querySelectorAll(".share-native-btn");

    nativeButtons.forEach((btn) => {
      // Show button only if Web Share API is available
      if (navigator.share) {
        (btn as HTMLElement).style.display = "";

        btn.addEventListener("click", async () => {
          try {
            await navigator.share({
              title: btn.getAttribute("data-share-title") || "",
              text: btn.getAttribute("data-share-text") || "",
              url: btn.getAttribute("data-share-url") || "",
            });
          } catch (err) {
            // User cancelled — not an error
            if (err instanceof Error && err.name !== "AbortError") {
              console.error("Share failed:", err);
            }
          }
        });
      }
    });
  });
</script>
