---
interface Props {
  subtle?: boolean;
  fixed?: boolean;
}

const { subtle = false, fixed = false } = Astro.props;
---

<canvas class={`agent-network ${subtle ? 'agent-network--subtle' : ''} ${fixed ? 'agent-network--fixed' : ''}`} id="agent-network" aria-hidden="true" data-subtle={subtle ? "true" : "false"}></canvas>

<style>
  .agent-network {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  
  .agent-network--fixed {
    position: fixed;
    z-index: -1;
  }
  
  @media (prefers-reduced-motion: reduce) {
    .agent-network { display: none; }
  }
</style>

<script>
  // ── Agent Network Animation ──
  // Run once per page if canvas exists
  function initAgentNetwork() {
    const canvas = document.getElementById('agent-network') as HTMLCanvasElement;
    if (!canvas) return;
    
    // Prevent double init
    if (canvas.dataset.initialized === 'true') return;
    canvas.dataset.initialized = 'true';
    
    const ctx = canvas.getContext('2d');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const isSubtle = canvas.getAttribute('data-subtle') === 'true';

    // ── Agent network canvas ──
    if (ctx && !prefersReducedMotion.matches) {
      const isMobile = window.innerWidth < 768;
      // Reduce nodes drastically if subtle
      const NODE_COUNT = isSubtle ? (isMobile ? 12 : 25) : (isMobile ? 30 : 55);
      const CONNECTION_DIST = isMobile ? 120 : 150;
      const TARGET_FPS = isMobile ? 30 : 60;
      const FRAME_INTERVAL = 1000 / TARGET_FPS;

      let nodes: any[] = [];
      let animId = 0;
      let lastFrame = 0;

      function isDark() {
        return document.documentElement.classList.contains('dark');
      }

      function getColors() {
        const dark = isDark();
        
        // If subtle mode, drop the opacities significantly so it doesn't distract readable content
        const nodeAlpha = isSubtle ? 0.2 : (dark ? 0.6 : 0.55);
        const pulseAlpha = isSubtle ? 0.3 : 1;
        const lineMaxAlpha = isSubtle ? 0.15 : 0.35;
        const glowAlpha = isSubtle ? 0.1 : (dark ? 0.4 : 0.35);
        
        return {
          node: dark ? `rgba(45, 212, 191, ${nodeAlpha})` : `rgba(67, 56, 202, ${nodeAlpha})`,
          nodePulse: dark ? `rgba(45, 212, 191, ${pulseAlpha})` : `rgba(67, 56, 202, ${pulseAlpha})`,
          line: dark ? `rgba(45, 212, 191, __ALPHA__)` : `rgba(67, 56, 202, __ALPHA__)`,
          lineMultiplier: lineMaxAlpha,
          glow: dark ? `rgba(45, 212, 191, ${glowAlpha})` : `rgba(67, 56, 202, ${glowAlpha})`,
        };
      }

      function resize() {
        // If parent has relative positioning, getBoundingClientRect returns size of parent
        const parent = canvas.parentElement || document.body;
        const rect = parent.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx!.scale(dpr, dpr);
      }

      function initNodes() {
        const parent = canvas.parentElement || document.body;
        const w = parent.getBoundingClientRect().width;
        const h = parent.getBoundingClientRect().height;
        nodes = [];
        for (let i = 0; i < NODE_COUNT; i++) {
          nodes.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * (isSubtle ? 0.2 : 0.4),
            vy: (Math.random() - 0.5) * (isSubtle ? 0.2 : 0.4),
            radius: 2 + Math.random() * 2,
            pulsePhase: Math.random() * Math.PI * 2,
            pulseSpeed: 0.02 + Math.random() * 0.02,
            isPulsing: false,
            pulseTimer: Math.random() * 400,
          });
        }
      }

      function draw(timestamp: number) {
        if (document.hidden) {
          animId = requestAnimationFrame(draw);
          return;
        }

        const elapsed = timestamp - lastFrame;
        if (elapsed < FRAME_INTERVAL) {
          animId = requestAnimationFrame(draw);
          return;
        }
        lastFrame = timestamp - (elapsed % FRAME_INTERVAL);

        const parent = canvas.parentElement || document.body;
        const rect = parent.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        const colors = getColors();

        ctx!.clearRect(0, 0, w, h);

        // Update node positions
        for (const node of nodes) {
          node.x += node.vx;
          node.y += node.vy;

          // Bounce off edges with padding
          if (node.x < 0 || node.x > w) node.vx *= -1;
          if (node.y < 0 || node.y > h) node.vy *= -1;
          node.x = Math.max(0, Math.min(w, node.x));
          node.y = Math.max(0, Math.min(h, node.y));

          // Pulse timer
          node.pulseTimer--;
          if (node.pulseTimer <= 0) {
            node.isPulsing = true;
            node.pulseTimer = 300 + Math.random() * 500;
          }
          node.pulsePhase += node.pulseSpeed;
          if (node.pulsePhase > Math.PI * 2) {
            node.isPulsing = false;
            node.pulsePhase -= Math.PI * 2;
          }
        }

        // Draw connections
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const dx = nodes[i].x - nodes[j].x;
            const dy = nodes[i].y - nodes[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < CONNECTION_DIST) {
              const alpha = (1 - dist / CONNECTION_DIST) * colors.lineMultiplier;
              ctx!.beginPath();
              ctx!.moveTo(nodes[i].x, nodes[i].y);
              ctx!.lineTo(nodes[j].x, nodes[j].y);
              ctx!.strokeStyle = colors.line.replace('__ALPHA__', String(alpha));
              ctx!.lineWidth = 1;
              ctx!.stroke();
            }
          }
        }

        // Draw nodes
        for (const node of nodes) {
          const pulseScale = node.isPulsing ? 1 + Math.sin(node.pulsePhase) * 0.8 : 1;
          const r = node.radius * pulseScale;

          // Glow for pulsing nodes
          if (node.isPulsing && pulseScale > 1.3) {
            ctx!.beginPath();
            ctx!.arc(node.x, node.y, r * 3, 0, Math.PI * 2);
            ctx!.fillStyle = colors.glow;
            ctx!.fill();
          }

          ctx!.beginPath();
          ctx!.arc(node.x, node.y, r, 0, Math.PI * 2);
          ctx!.fillStyle = node.isPulsing ? colors.nodePulse : colors.node;
          ctx!.fill();
        }

        animId = requestAnimationFrame(draw);
      }

      // Init
      resize();
      initNodes();
      animId = requestAnimationFrame(draw);

      // Resize handler
      window.addEventListener('resize', () => {
        resize();
        initNodes();
      });

      // Theme change observer
      const observer = new MutationObserver(() => {});
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    }
  }

  // Initialize on astro page load
  document.addEventListener("astro:page-load", initAgentNetwork);
  // Also run initially if not using view transitions
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initAgentNetwork();
  } else {
    document.addEventListener('DOMContentLoaded', initAgentNetwork);
  }
</script>
