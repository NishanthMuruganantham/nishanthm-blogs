---
interface Props {
  subtle?: boolean;
  fixed?: boolean;
}

const { subtle = false, fixed = false } = Astro.props;
---

<canvas
  class={`agent-network ${subtle ? "agent-network--subtle" : ""} ${fixed ? "agent-network--fixed" : ""}`}
  id="agent-network"
  aria-hidden="true"
  data-subtle={subtle ? "true" : "false"}></canvas>

<style>
  .agent-network {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .agent-network--fixed {
    position: fixed;
    z-index: -1;
  }

  @media (prefers-reduced-motion: reduce) {
    .agent-network {
      display: none;
    }
  }
</style>

<script>
  // ── Sparks Vortex Animation ──
  // Run once per page if canvas exists
  function initAgentNetwork() {
    const canvas = document.getElementById(
      "agent-network",
    ) as HTMLCanvasElement;
    if (!canvas) return;

    // Prevent double init
    if (canvas.dataset.initialized === "true") return;
    canvas.dataset.initialized = "true";

    const ctx = canvas.getContext("2d");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );
    const isSubtle = canvas.getAttribute("data-subtle") === "true";

    if (ctx && !prefersReducedMotion.matches) {
      const isMobile = window.innerWidth < 768;
      // More nodes required for sparks effect
      const NODE_COUNT = isSubtle ? (isMobile ? 30 : 60) : isMobile ? 80 : 300;
      const TARGET_FPS = isMobile ? 30 : 60;
      const FRAME_INTERVAL = 1000 / TARGET_FPS;

      // Vibrant palette inspired by Google/Antigravity
      const SPARK_COLORS = [
        "#4285F4",
        "#EA4335",
        "#FBBC05",
        "#34A853",
        "#8A2BE2",
        "#FF7F50",
        "#0D9488",
      ];

      let nodes: any[] = [];
      let animId = 0;
      let lastFrame = 0;
      
      // Mouse tracking state
      let mouseX = -1000;
      let mouseY = -1000;
      let isHovering = false;

      function resize() {
        const parent = canvas.parentElement || document.body;
        const rect = parent.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx!.scale(dpr, dpr);
      }

      function initNodes() {
        const parent = canvas.parentElement || document.body;
        const rect = parent.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        nodes = [];
        for (let i = 0; i < NODE_COUNT; i++) {
          nodes.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5,
            length: Math.random() * 8 + 4, // 4 to 12
            thickness: Math.random() * 2 + 1.5, // 1.5 to 3.5
            color:
              SPARK_COLORS[Math.floor(Math.random() * SPARK_COLORS.length)],
            baseOpacity: Math.random() * 0.5 + 0.3,
            pulseSpeed: Math.random() * 0.02 + 0.01,
            pulsePhase: Math.random() * Math.PI * 2,
            cx: w * 0.3, // Vortex center X (slightly left)
            cy: h * 0.5, // Vortex center Y (middle)
          });
        }
      }

      function draw(timestamp: number) {
        if (document.hidden) {
          animId = requestAnimationFrame(draw);
          return;
        }

        const elapsed = timestamp - lastFrame;
        if (elapsed < FRAME_INTERVAL) {
          animId = requestAnimationFrame(draw);
          return;
        }
        lastFrame = timestamp - (elapsed % FRAME_INTERVAL);

        const parent = canvas.parentElement || document.body;
        const rect = parent.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        const defaultCx = w * 0.3;
        const defaultCy = h * 0.5;

        ctx!.clearRect(0, 0, w, h);

        // Update node positions and draw
        for (const node of nodes) {
          
          // Smoothly move the vortex center towards the mouse, or back to default
          if (isHovering) {
            node.cx = node.cx * 0.95 + mouseX * 0.05;
            node.cy = node.cy * 0.95 + mouseY * 0.05;
            
            // Add a slight repelling force if spark gets too close to the actual cursor
            const mdX = node.x - mouseX;
            const mdY = node.y - mouseY;
            const mDist = Math.sqrt(mdX * mdX + mdY * mdY) || 1;
            if (mDist < 120) {
              node.vx += (mdX / mDist) * 0.05;
              node.vy += (mdY / mDist) * 0.05;
            }
          } else {
            node.cx = node.cx * 0.98 + defaultCx * 0.02;
            node.cy = node.cy * 0.98 + defaultCy * 0.02;
          }

          // Dynamic vortex center to avoid identical paths initially
          const dx = node.x - node.cx;
          const dy = node.y - node.cy;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;

          // Tangent vector for spiral/vortex effect
          const tx = -dy / dist;
          const ty = dx / dist;

          // Blend current velocity with tangent vector
          node.vx = node.vx * 0.98 + tx * 0.03;
          node.vy = node.vy * 0.98 + ty * 0.03;

          // Add a tiny bit of random drift
          node.vx += (Math.random() - 0.5) * 0.08;
          node.vy += (Math.random() - 0.5) * 0.08;

          // Speed limit
          const speed = Math.sqrt(node.vx * node.vx + node.vy * node.vy);
          if (speed > 1.2) {
            node.vx = (node.vx / speed) * 1.2;
            node.vy = (node.vy / speed) * 1.2;
          }

          node.x += node.vx;
          node.y += node.vy;

          // Wrap around edges
          if (node.x < -20) node.x = w + 20;
          if (node.x > w + 20) node.x = -20;
          if (node.y < -20) node.y = h + 20;
          if (node.y > h + 20) node.y = -20;

          const angle = Math.atan2(node.vy, node.vx);
          node.pulsePhase += node.pulseSpeed;
          const opacity = Math.max(
            0,
            Math.min(1, node.baseOpacity + Math.sin(node.pulsePhase) * 0.4),
          );

          ctx!.save();
          ctx!.translate(node.x, node.y);
          ctx!.rotate(angle);
          ctx!.globalAlpha = isSubtle ? opacity * 0.35 : opacity;
          ctx!.fillStyle = node.color;
          ctx!.beginPath();
          // Draw pill shape spark
          ctx!.roundRect(
            -node.length / 2,
            -node.thickness / 2,
            node.length,
            node.thickness,
            node.thickness / 2,
          );
          ctx!.fill();
          ctx!.restore();
        }

        animId = requestAnimationFrame(draw);
      }

      // Init
      resize();
      initNodes();
      animId = requestAnimationFrame(draw);

      // Resize handler
      window.addEventListener("resize", () => {
        resize();
        initNodes();
      });
      
      // Mouse interaction event listeners (Attached to window to bypass pointer-events: none on canvas)
      window.addEventListener("mousemove", (e) => {
        const rect = canvas.getBoundingClientRect();
        // Only track if mouse is over the hero section/canvas bounds
        if (
          e.clientY >= rect.top &&
          e.clientY <= Math.max(rect.bottom, window.innerHeight * 0.8) && 
          e.clientX >= rect.left &&
          e.clientX <= rect.right
        ) {
          mouseX = e.clientX - rect.left;
          mouseY = e.clientY - rect.top;
          isHovering = true;
        } else {
          isHovering = false;
        }
      });

      window.addEventListener("mouseout", (e) => {
        if (!e.relatedTarget && !e.toElement) {
          isHovering = false;
        }
      });
    }
  }

  // Initialize on astro page load
  document.addEventListener("astro:page-load", initAgentNetwork);
  // Also run initially if not using view transitions
  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    initAgentNetwork();
  } else {
    document.addEventListener("DOMContentLoaded", initAgentNetwork);
  }
</script>
