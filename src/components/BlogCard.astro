---
interface Props {
  id?: string;
  title: string;
  description: string;
  excerpt?: string;
  date: string | Date;
  category: string;
  tags: string[];
  slug: string;
  cover?: string;
  readingTime?: string;
}

const { title, description, excerpt, date, category, tags = [], slug, cover, readingTime } = Astro.props;

const dateStr = typeof date === 'string' ? date : new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<div class="blog-card" data-post-slug={slug}>
  <div class="blog-card-content">
    <span class="category-badge">{category}</span>
    <h2 class="card-title">{title}</h2>
    <p class="card-excerpt">{description || excerpt}</p>
    
    <div class="card-metadata">
      <time datetime={typeof date === 'string' ? date : date.toISOString()} class="date">{dateStr}</time>
      <span class="read-time">{readingTime || '3 min read'}</span>
    </div>
    
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
    
    <a href={`/blog/${slug}/`} class="read-more">Read more &rarr;</a>
  </div>
  
  <div class="blog-card-image">
    {cover ? (
      <img src={cover} alt={title} loading="lazy" decoding="async" />
    ) : (
      <div class="image-fallback"></div>
    )}
  </div>
</div>
