---
// EmailCapture.astro — Newsletter signup widget
// Issue #50: post-completion CTA, matches design system, Buttondown integration
interface Props {
  heading?: string;
  subheading?: string;
  buttonText?: string;
}

const {
  heading = "Want more like this?",
  subheading = "I write about Django, React, and Android development every week. Practical tutorials and real-world solutions — no spam.",
  buttonText = "Subscribe →",
} = Astro.props;

const formId = `email-capture-${Math.random().toString(36).slice(2, 7)}`;
---

<section class="email-capture" aria-label="Newsletter signup">
  <div class="email-capture-inner">
    <div class="email-capture-icon" aria-hidden="true">💌</div>

    <div class="email-capture-content">
      <h3 class="email-capture-heading">{heading}</h3>
      <p class="email-capture-subheading">{subheading}</p>

      <form
        id={formId}
        class="email-capture-form"
        action="https://buttondown.email/api/emails/embed-subscribe/nishanthm"
        method="post"
        target="_blank"
        novalidate
      >
        <input type="hidden" name="embed" value="1" />
        <div class="email-capture-row">
          <label for={`${formId}-input`} class="sr-only">Email address</label>
          <input
            id={`${formId}-input`}
            type="email"
            name="email"
            placeholder="your@email.com"
            autocomplete="email"
            required
            class="email-input"
            aria-required="true"
          />
          <button type="submit" class="email-btn">
            {buttonText}
          </button>
        </div>
        <p class="email-privacy">
          Join 500+ developers. Unsubscribe anytime — no spam, ever.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .email-capture {
    margin: 3rem 0 2rem;
    border-radius: 1rem;
    /* Glassmorphism panel */
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: hidden;
    position: relative;
  }

  /* Subtle accent gradient strip at top */
  .email-capture::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-bright) 100%
    );
  }

  .email-capture-inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem 2.5rem;
  }

  .email-capture-icon {
    font-size: 2.25rem;
    line-height: 1;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 6px var(--color-accent-glow));
  }

  .email-capture-content {
    flex: 1;
    min-width: 0;
  }

  .email-capture-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .email-capture-subheading {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .email-capture-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .email-capture-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .email-input {
    flex: 1;
    min-width: 220px;
    padding: 0.65rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 0.9rem;
    transition:
      border-color 200ms ease,
      box-shadow 200ms ease;
    outline: none;
  }

  .email-input::placeholder {
    color: var(--color-text-muted);
  }

  .email-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }

  .email-btn {
    padding: 0.65rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    border: none;
    border-radius: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 150ms ease,
      box-shadow 150ms ease,
      background 150ms ease;
    white-space: nowrap;
  }

  .email-btn:hover {
    background: var(--color-accent-bright);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--color-accent-glow);
  }

  .email-btn:active {
    transform: translateY(0);
    box-shadow: none;
  }

  .email-privacy {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    font-family: var(--font-display);
  }

  /* Screen-reader-only label */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Mobile: stack icon + content vertically */
  @media (max-width: 600px) {
    .email-capture-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.75rem 1.25rem;
    }

    .email-capture-row {
      flex-direction: column;
    }

    .email-input {
      min-width: 0;
      width: 100%;
    }

    .email-btn {
      width: 100%;
    }
  }
</style>
