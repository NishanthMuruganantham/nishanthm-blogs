---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          nishanth<span class="footer-dot">.</span>dev
        </a>
        <p class="footer-tagline">
          Building real systems. Documenting the journey.
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="footer-col">
        <h4 class="footer-heading">Quick Links</h4>
        <ul class="footer-links">
          {quickLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Social -->
      <div class="footer-col">
        <h4 class="footer-heading">Connect</h4>
        <ul class="footer-socials">
          {socialLinks.map(link => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
                aria-label={link.label}
              >
                <Fragment set:html={link.icon} />
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>
        &copy; {currentYear} Nishanth M &middot; Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
      <a href="/rss.xml" class="rss-link" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="6.18" cy="17.82" r="2.18"/>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    padding: 0;
    overflow: hidden;
    /* Light Mode Defaults */
    background-color: #f9fafb;
    border-top: 1px solid rgba(16, 185, 129, 0.1);
    color: #374151;
    transition: all 0.3s ease;
    margin-top: var(--space-section);
  }

  :global(.dark) .site-footer {
    background-color: #050f09;
    background-image: 
      radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.05) 0%, transparent 70%),
      linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.4));
    border-top: 1px solid rgba(16, 185, 129, 0.2);
    color: #ecfdf5;
  }

  .footer-inner {
    max-width: var(--wide-width);
    margin: 0 auto;
    padding: 5rem 1.5rem 3rem;
    position: relative;
    z-index: 10;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-logo {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
    display: block;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .footer-dot {
    color: var(--color-accent-bright);
    text-shadow: 0 0 10px var(--color-accent-glow);
    -webkit-text-fill-color: initial;
  }

  .footer-tagline {
    color: #4b5563;
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 1.05rem;
    max-width: 300px;
  }

  :global(.dark) .footer-tagline {
    color: #94a3b8;
  }

  .footer-heading {
    color: #111827;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  :global(.dark) .footer-heading {
    color: #f8fafc;
  }

  .footer-links,
  .footer-socials {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li,
  .footer-socials li {
    margin-bottom: 1rem;
  }

  .footer-links a,
  .social-link {
    color: #4b5563;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
  }

  :global(.dark) .footer-links a,
  :global(.dark) .social-link {
    color: #94a3b8;
  }

  .footer-links a:hover,
  .social-link:hover {
    color: #10b981;
    transform: translateX(4px);
  }

  .social-link svg {
    flex-shrink: 0;
  }

  /* Bottom bar */
  .footer-bottom {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    color: #6b7280;
  }

  :global(.dark) .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    color: #64748b;
  }

  .footer-bottom a {
    color: #10b981;
    font-weight: 600;
    text-decoration: none;
  }

  .rss-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.03);
    color: #6b7280;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.2s ease;
  }

  :global(.dark) .rss-link {
    background: rgba(255, 255, 255, 0.03);
    color: #94a3b8;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rss-link:hover {
    background: var(--color-accent-glow);
    color: #10b981;
    border-color: #10b981;
    transform: scale(1.1);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .footer-inner {
      padding-top: 3rem;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>
