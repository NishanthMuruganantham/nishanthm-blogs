---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  ogType?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
  ogType,
  publishedDate,
  tags,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      ogType={ogType}
      publishedDate={publishedDate}
      tags={tags}
    />
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .site-main {
    min-height: 100vh;
    padding-top: 4.5rem; /* offset for fixed header */
  }
</style>
